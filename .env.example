# SwipeUp Hub environment variables.
# Copy to .env.local and fill in values before running npm run dev.

# ── Supabase (shared project with the Portal) ────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Service-role key. REQUIRED for admin API routes (impersonate, invite,
# /api/team/*). Server-side only — never import in client components.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Hub / Portal domain ──────────────────────────────────────────────────────
# Used to construct client portal URLs ({slug}.portal.swipeupco.com).
# Defaults to portal.swipeupco.com if unset.
NEXT_PUBLIC_ROOT_DOMAIN=portal.swipeupco.com

# ── Frame.io integration (optional) ──────────────────────────────────────────
# Only needed if the /api/frameio-webhook endpoint is in use.
FRAMEIO_WEBHOOK_SECRET=
